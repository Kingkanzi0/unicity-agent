# Copy this file to .env and fill in the values.

# The Unicity ID (nametag) your agent will claim, e.g. "buildbot_alex".
# 3-20 chars, lowercase letters/numbers/_/-.  Pick something unique -
# nametags are first-come-first-served on testnet.
AGENT_NAMETAG=buildbot_replace_me

# Optional: fix your agent's recovery phrase so it keeps the same identity
# across restarts/deploys. If left blank, the SDK auto-generates one on
# first run and saves it to ./wallet-data - back that up instead.
WALLET_MNEMONIC=

# The Unicity testnet2 gateway API key. It is NOT a secret - it is published
# in the sphere-sdk repo's own .env.example file, safe to check into a demo
# repo. Get the current value from:
# https://github.com/unicity-sphere/sphere-sdk/blob/main/.env.example
ORACLE_API_KEY=paste_the_public_testnet2_key_here

# Port the local web dashboard runs on.
PORT=3000

# Maximum amount (in whole UCT) the agent will auto-accept from an
# incoming payment request without a human reviewing it first.
AUTO_ACCEPT_MAX_UCT=5
